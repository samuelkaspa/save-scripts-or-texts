<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoScript Cyber Workspace</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    
    <style>
        :root {
            --bg: #e0e8f6;
            --primary: #4d76a3;
            --primary-glow: rgba(77, 118, 163, 0.4);
            --text: #3d4f68;
            --shadow-light: #ffffff;
            --shadow-dark: #b8c4d9;
            --fav-color: #ff5e7e;
            --success: #4caf50;
            --success-glow: rgba(76, 175, 80, 0.4);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }

        header {
            width: 100%;
            max-width: 900px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
            animation: slideDown 1s cubic-bezier(0.19, 1, 0.22, 1);
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 700;
            text-shadow: 1px 1px 2px var(--shadow-light);
            letter-spacing: -0.5px;
        }

        /* Ferramentas Neomórficas com Animação */
        .search-container {
            position: relative;
            flex-grow: 1;
            max-width: 450px;
            margin-right: 1.5rem;
            transition: transform 0.3s ease;
        }

        .search-container:focus-within {
            transform: scale(1.02);
        }

        .search-input {
            width: 100%;
            padding: 14px 20px 14px 50px;
            border: none;
            outline: none;
            border-radius: 18px;
            background: var(--bg);
            box-shadow: inset 6px 6px 12px var(--shadow-dark), inset -6px -6px 12px var(--shadow-light);
            color: var(--text);
            font-size: 0.95rem;
            transition: box-shadow 0.3s ease;
        }

        .search-input:focus {
            box-shadow: inset 3px 3px 6px var(--shadow-dark), inset -3px -3px 6px var(--shadow-light);
        }

        .search-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            transition: transform 0.3s ease;
        }

        .search-container:focus-within .search-icon {
            transform: translateY(-50%) rotate(90deg) scale(1.1);
        }

        .btn-add {
            width: 52px;
            height: 52px;
            border: none;
            border-radius: 50%;
            background: var(--bg);
            box-shadow: 6px 6px 14px var(--shadow-dark), -6px -6px 14px var(--shadow-light);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-add:hover {
            transform: scale(1.1) rotate(180deg);
            box-shadow: 0px 0px 20px var(--primary-glow), 4px 4px 10px var(--shadow-dark), -4px -4px 10px var(--shadow-light);
        }

        .btn-add:active {
            box-shadow: inset 4px 4px 8px var(--shadow-dark), inset -4px -4px 8px var(--shadow-light);
            transform: scale(0.95);
        }

        /* Grid de Scripts */
        main {
            width: 100%;
            max-width: 900px;
        }

        .scripts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 25px;
        }

        /* Card Neomórfico Totalmente Clicável */
        .script-card {
            background: var(--bg);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 9px 9px 18px var(--shadow-dark), -9px -9px 18px var(--shadow-light);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 180px;
            position: relative;
            cursor: pointer;
            transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease;
            animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) backwards;
        }

        .script-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 14px 14px 28px var(--shadow-dark), -14px -14px 28px var(--shadow-light);
        }

        .script-card:active {
            transform: translateY(-2px) scale(0.99);
            box-shadow: inset 5px 5px 10px var(--shadow-dark), inset -5px -5px 10px var(--shadow-light);
        }

        .script-card h3 {
            font-size: 1.2rem;
            word-wrap: break-word;
            padding-right: 10px;
            font-weight: 600;
            pointer-events: none; /* Garante que o clique passe para o card */
        }

        .card-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }

        .btn-icon {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text);
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.3s;
            display: flex;
            align-items: center;
            padding: 8px;
            border-radius: 50%;
        }

        .btn-icon:hover {
            transform: scale(1.25);
            background: rgba(255, 255, 255, 0.4);
        }

        .btn-icon:active {
            transform: scale(0.9);
        }

        .btn-fav.active {
            color: var(--fav-color);
            animation: heartbeat 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        .btn-delete:hover {
            color: #ff3333;
        }

        /* Tela de Documento Expandida (Workspace) */
        .workspace-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg);
            display: flex;
            justify-content: center;
            padding: 2rem;
            opacity: 0;
            pointer-events: none;
            transform: translateY(100%);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
            z-index: 100;
        }

        .workspace-overlay.active {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        .document-panel {
            width: 100%;
            max-width: 900px;
            background: var(--bg);
            border-radius: 32px;
            padding: 30px;
            box-shadow: 15px 15px 35px var(--shadow-dark), -15px -15px 35px var(--shadow-light);
            display: flex;
            flex-direction: column;
            gap: 20px;
            height: 100%;
            animation: panelIntro 0.7s 0.1s cubic-bezier(0.16, 1, 0.3, 1) backwards;
        }

        .document-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--shadow-dark);
            padding-bottom: 15px;
        }

        .document-title-input {
            background: transparent;
            border: none;
            outline: none;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text);
            width: 60%;
            transition: border-bottom 0.3s;
        }

        .document-actions {
            display: flex;
            gap: 15px;
        }

        /* Editor Folha de Código Magnética */
        .editor-container {
            flex-grow: 1;
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: inset 7px 7px 14px var(--shadow-dark), inset -7px -7px 14px var(--shadow-light);
            background: var(--bg);
            padding: 24px;
        }

        .script-editor {
            width: 100%;
            height: 100%;
            background: transparent;
            border: none;
            outline: none;
            resize: none;
            font-family: 'Fira Code', monospace;
            font-size: 1.05rem;
            color: #2b3a4a;
            line-height: 1.6;
            user-select: text;
        }

        .btn-action {
            padding: 12px 22px;
            border: none;
            border-radius: 16px;
            background: var(--bg);
            box-shadow: 5px 5px 11px var(--shadow-dark), -5px -5px 11px var(--shadow-light);
            cursor: pointer;
            font-weight: 600;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .btn-action:hover {
            transform: translateY(-3px);
        }

        .btn-save-script:hover {
            color: var(--success);
            box-shadow: 0px 0px 15px var(--success-glow), 4px 4px 10px var(--shadow-dark), -4px -4px 10px var(--shadow-light);
        }

        .btn-copy-script:hover {
            color: var(--primary);
            box-shadow: 0px 0px 15px var(--primary-glow), 4px 4px 10px var(--shadow-dark), -4px -4px 10px var(--shadow-light);
        }

        .btn-action:active {
            box-shadow: inset 3px 3px 6px var(--shadow-dark), inset -3px -3px 6px var(--shadow-light);
            transform: translateY(1px) scale(0.98);
        }

        /* Animações Avançadas */
        @keyframes slideDown {
            from { transform: translateY(-70px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @keyframes popIn {
            from { transform: scale(0.6) translateY(40px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }

        @keyframes panelIntro {
            from { transform: scale(0.95) translateY(20px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }

        @keyframes heartbeat {
            0% { transform: scale(1); }
            30% { transform: scale(1.5); }
            45% { transform: scale(1.2); }
            70% { transform: scale(1.4); }
            100% { transform: scale(1); }
        }

        .fade-out {
            animation: fadeOut 0.4s cubic-bezier(0.4, 0, 1, 1) forwards !important;
        }

        @keyframes fadeOut {
            to { opacity: 0; transform: scale(0.8) translateY(-30px); }
        }
    </style>
</head>
<body>

    <header>
        <h1>NeoScripts</h1>
        <div class="search-container">
            <span class="material-icons search-icon">search</span>
            <input type="text" id="search" class="search-input" placeholder="Pesquisar script pelo nome...">
        </div>
        <button class="btn-add" id="createNewBtn" title="Criar Novo Script">
            <span class="material-icons">add</span>
        </button>
    </header>

    <main>
        <div class="scripts-grid" id="scriptsGrid">
            </div>
    </main>

    <div class="workspace-overlay" id="workspaceOverlay">
        <div class="document-panel">
            <div class="document-header">
                <input type="text" id="documentTitle" class="document-title-input" placeholder="Nome do seu Script...">
                <input type="hidden" id="currentScriptId">
                
                <div class="document-actions">
                    <button class="btn-action btn-copy-script" id="copyScriptBtn">
                        <span class="material-icons">content_copy</span> Copiar
                    </button>
                    <button class="btn-action btn-save-script" id="saveScriptBtn">
                        <span class="material-icons">save</span> Salvar Alterações
                    </button>
                    <button class="btn-action" id="closeWorkspaceBtn">
                        <span class="material-icons">close</span> Fechar
                    </button>
                </div>
            </div>

            <div class="editor-container">
                <textarea id="documentEditor" class="script-editor" placeholder="// Modifique ou reescreva seu código à vontade aqui..."></textarea>
            </div>
        </div>
    </div>

    <script>
        let scripts = JSON.parse(localStorage.getItem('neo_scripts_v3')) || [];

        const scriptsGrid = document.getElementById('scriptsGrid');
        const workspaceOverlay = document.getElementById('workspaceOverlay');
        const createNewBtn = document.getElementById('createNewBtn');
        const closeWorkspaceBtn = document.getElementById('closeWorkspaceBtn');
        const saveScriptBtn = document.getElementById('saveScriptBtn');
        const copyScriptBtn = document.getElementById('copyScriptBtn');
        const searchInput = document.getElementById('search');

        const currentScriptId = document.getElementById('currentScriptId');
        const documentTitle = document.getElementById('documentTitle');
        const documentEditor = document.getElementById('documentEditor');

        function renderScripts(filterText = '') {
            scriptsGrid.innerHTML = '';
            
            const sortedScripts = [...scripts].sort((a, b) => b.favorite - a.favorite);

            sortedScripts.forEach((script, index) => {
                if (!script.name.toLowerCase().includes(filterText.toLowerCase())) return;

                const card = document.createElement('div');
                card.className = 'script-card';
                card.style.animationDelay = `${index * 0.05}s`;
                // Configura o clique em qualquer lugar do card para abrir a área de edição
                card.setAttribute('onclick', `openWorkspace('${script.id}')`);
                
                card.innerHTML = `
                    <h3>${script.name}</h3>
                    <div class="card-actions">
                        <button class="btn-icon btn-fav ${script.favorite ? 'active' : ''}" onclick="toggleFavorite('${script.id}', event)">
                            <span class="material-icons">${script.favorite ? 'favorite' : 'favorite_border'}</span>
                        </button>
                        <button class="btn-icon btn-delete" onclick="deleteScript('${script.id}', event)">
                            <span class="material-icons">delete</span>
                        </button>
                    </div>
                `;
                
                scriptsGrid.appendChild(card);
            });
        }

        createNewBtn.addEventListener('click', () => {
            currentScriptId.value = '';
            documentTitle.value = '';
            documentEditor.value = '';
            workspaceOverlay.classList.add('active');
            documentTitle.focus();
        });

        // Puxa as informações e reabre na tela de documento para copiar/atualizar
        window.openWorkspace = function(id) {
            const script = scripts.find(s => s.id === id);
            if (!script) return;

            currentScriptId.value = script.id;
            documentTitle.value = script.name;
            documentEditor.value = script.content;
            workspaceOverlay.classList.add('active');
        };

        closeWorkspaceBtn.addEventListener('click', () => {
            workspaceOverlay.classList.remove('active');
        });

        // Salva e mantém as modificações reescritas
        saveScriptBtn.addEventListener('click', () => {
            const name = documentTitle.value.trim();
            const content = documentEditor.value.trim();
            const id = currentScriptId.value;

            if (!name || !content) return;

            if (id) {
                // Reescreve o documento existente
                const index = scripts.findIndex(s => s.id === id);
                scripts[index].name = name;
                scripts[index].content = content;
            } else {
                // Cria um novo
                const newScript = {
                    id: Date.now().toString(),
                    name: name,
                    content: content,
                    favorite: false
                };
                scripts.push(newScript);
            }

            saveToLocalStorage();
            workspaceOverlay.classList.remove('active');
            setTimeout(() => renderScripts(searchInput.value), 300);
        });

        copyScriptBtn.addEventListener('click', () => {
            if (!documentEditor.value.trim()) return;
            
            navigator.clipboard.writeText(documentEditor.value).then(() => {
                const originalText = copyScriptBtn.innerHTML;
                copyScriptBtn.innerHTML = `<span class="material-icons" style="color:var(--success)">check</span> Copiado!`;
                setTimeout(() => {
                    copyScriptBtn.innerHTML = originalText;
                }, 1500);
            });
        });

        window.toggleFavorite = function(id, event) {
            event.stopPropagation(); // Impede o card de abrir quando clica em favoritar
            const script = scripts.find(s => s.id === id);
            if (script) {
                script.favorite = !script.favorite;
                saveToLocalStorage();
                renderScripts(searchInput.value);
            }
        };

        window.deleteScript = function(id, event) {
            event.stopPropagation(); // Impede o card de abrir quando clica em deletar
            const card = event.target.closest('.script-card');
            card.classList.add('fade-out');
            
            setTimeout(() => {
                scripts = scripts.filter(s => s.id !== id);
                saveToLocalStorage();
                renderScripts(searchInput.value);
            }, 400);
        };

        searchInput.addEventListener('input', (e) => {
            renderScripts(e.target.value);
        });

        function saveToLocalStorage() {
            localStorage.setItem('neo_scripts_v3', JSON.stringify(scripts));
        }

        renderScripts();
    </script>
</body>
</html>